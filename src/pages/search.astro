---
// 정적 전문 검색 페이지. 빌드 후 pagefind가 dist/pagefind/ 에 색인·UI를 만든다.
// (astro dev 에서는 색인이 없어 동작하지 않음 — 빌드/preview 또는 배포본에서만 검색됨)
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="검색" description="블로그 글 검색" noindex={true}>
  <div class="search-page">
    <h1 class="search-page__title">검색</h1>
    <div id="search" class="search-page__box"></div>
    <noscript>검색 기능은 자바스크립트가 필요합니다.</noscript>
  </div>
</BaseLayout>

<!-- Pagefind 기본 UI(빌드 산출물). 절대경로라 번들에 포함되지 않고 런타임에 불러온다. -->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script>
  // 페이지 전환(View Transitions)마다 검색 UI를 다시 붙인다.
  function initSearch() {
    const el = document.querySelector('#search');
    if (!el || el.childElementCount > 0) return; // 이미 초기화됨
    // biome-ignore lint/suspicious/noExplicitAny: Pagefind UI는 전역에 주입되는 외부 스크립트
    const w = window as any;
    if (!w.PagefindUI) return;
    new w.PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      translations: {
        placeholder: '검색어를 입력하세요',
        clear_search: '지우기',
        load_more: '더 보기',
        search_label: '이 블로그 검색',
        zero_results: '“[SEARCH_TERM]” 검색 결과가 없어요',
        many_results: '“[SEARCH_TERM]” 검색 결과 [COUNT]개',
        one_result: '“[SEARCH_TERM]” 검색 결과 [COUNT]개',
        searching: '“[SEARCH_TERM]” 검색 중…',
      },
    });
  }

  function loadPagefind() {
    if (!document.querySelector('#search')) return; // 검색 페이지가 아닐 때
    if (document.querySelector('script[data-pagefind-ui]')) {
      initSearch();
      return;
    }
    const s = document.createElement('script');
    s.src = '/pagefind/pagefind-ui.js';
    s.setAttribute('data-pagefind-ui', '');
    s.onload = initSearch;
    document.head.appendChild(s);
  }

  document.addEventListener('astro:page-load', loadPagefind);
</script>

<style lang="scss">
  @import '../styles/variables';
  @import '../styles/mixins';

  .search-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 15px;
    // 결과가 적거나 없을 때도 footer가 위로 붙지 않도록 최소 높이를 준다.
    // (본문↔footer 간격 자체는 footer의 margin-top이 담당)
    min-height: 60vh;

    &__title {
      @include margin-bottom(1);
    }

    &__box {
      @include margin-top(1);
    }
  }

  // Pagefind 기본 UI를 사이트 테마(다크모드 포함)에 맞춘다.
  // 변수는 Pagefind가 .pagefind-ui 에 정의하므로 같은 선택자에서 덮어써야 한다.
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--c-primary);
    --pagefind-ui-text: var(--c-text);
    --pagefind-ui-background: var(--c-bg);
    --pagefind-ui-border: var(--c-border);
    --pagefind-ui-tag: var(--c-surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
  }
</style>
