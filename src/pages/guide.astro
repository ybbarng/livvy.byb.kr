---
// 글쓰기 가이드 (검색엔진 제외 · 메뉴에 안 넣음, URL /guide/ 로만 접근)
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content } from '../guide-content.md';
---

<BaseLayout title="글쓰기 가이드" description="블로그 글쓰기 문법 안내" noindex={true}>
  <div class="guide">
    <h1 class="guide__title">글쓰기 가이드</h1>
    <Content />
  </div>
</BaseLayout>

<style lang="scss">
  @import '../styles/variables';
  @import '../styles/mixins';

  .guide {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 15px;

    &__title {
      @include margin-bottom(1);
    }

    :global(h2) {
      @include margin-top(1.5);
      font-size: $typographic-base-font-size * 1.3;
    }

    :global(p),
    :global(li) {
      line-height: 1.9;
    }
  }
</style>
