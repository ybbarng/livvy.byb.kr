---
// 가변 폰트(fontsource) — font-display:swap + unicode-range subset 내장.
// 브라우저가 글자에 맞는 언어 폰트만 자동으로 받는다.
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/noto-sans-kr';
import '@fontsource-variable/noto-sans-jp';
import '@fontsource-variable/noto-sans-sc';
import '@fontsource-variable/roboto';
// 전역 스타일 진입점(기존 Gatsby init.scss 그대로 이식)
import '../styles/init.scss';
// fontello 아이콘 폰트(소셜 링크용)
import '../assets/fonts/fontello-3d8dd48a/css/fontello.css';

import Header from '../components/Header.astro';
import Copyright from '../components/Copyright.astro';
import { site } from '../config/site';
import ogImage from '../assets/images/blog_logo_og.png';

interface Props {
  title?: string;
  description?: string;
}
const { title = site.title, description = site.subtitle } = Astro.props;
const fullTitle = title === site.title ? title : `${title} - ${site.title}`;
const ogImageUrl = new URL(ogImage.src, Astro.site).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:locale" content="ko_KR" />
    <link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
  </head>
  <body>
    <div class="page">
      <Header />
      <div class="layout">
        <div class="layout__body">
          <slot />
        </div>
        <Copyright />
      </div>
    </div>
  </body>
</html>

<style lang="scss">
  @import '../styles/variables';

  // 기존 Layout/style.scss 이식: 고정 헤더(45px)만큼 본문을 아래로 민다 + clearfix
  .page {
    margin-top: $header-height;
  }

  .layout__body::after {
    content: "";
    display: block;
    clear: both;
  }
</style>
