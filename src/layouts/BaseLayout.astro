---
// 가변 폰트(fontsource) — font-display:swap + unicode-range subset 내장.
// 브라우저가 글자에 맞는 언어 폰트만 자동으로 받는다.
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/noto-sans-kr';
import '@fontsource-variable/noto-sans-jp';
import '@fontsource-variable/noto-sans-sc';
import '@fontsource-variable/roboto';
// 전역 스타일 진입점(기존 Gatsby init.scss 그대로 이식)
import '../styles/init.scss';

import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Copyright from '../components/Copyright.astro';
import { site } from '../config/site';
import ogImage from '../assets/images/blog_logo_og.png';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  // 글별 OG 이미지 경로(예: /og/slug.png). 없으면 공통 로고 이미지를 쓴다.
  ogImage?: string;
}
const { title = site.title, description = site.subtitle, noindex = false, ogImage: ogImageProp } =
  Astro.props;
const fullTitle = title === site.title ? title : `${title} - ${site.title}`;
// 글별 OG는 1200×630 가로형(SNS 큰 카드), 공통 로고는 800×800 정사각형.
const ogImageUrl = ogImageProp
  ? new URL(ogImageProp, Astro.site).href
  : new URL(ogImage.src, Astro.site).href;
const ogImageWidth = ogImageProp ? 1200 : 800;
const ogImageHeight = ogImageProp ? 630 : 800;
const twitterCard = ogImageProp ? 'summary_large_image' : 'summary';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <script is:inline>
      // 다크모드: 렌더 전에 저장된/OS 선호 테마를 적용해 깜빡임을 막는다.
      // View Transitions로 페이지가 바뀔 때도 다시 적용해 테마가 유지되게 한다.
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem('theme');
            if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
            else document.documentElement.removeAttribute('data-theme');
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
    <ClientRouter />
    <script is:inline>
      // 옛 Gatsby(gatsby-plugin-offline) Service Worker 잔재 제거.
      // 남아 있으면 페이지 이동을 가로채 존재하지 않는 page-data.json 을 요청해 화면이 깨진다.
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then((rs) => rs.forEach((r) => r.unregister()));
        if (window.caches) caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
      }
    </script>
    {/* Cloudflare Web Analytics — 쿠키 없음·개인정보 미수집. spa:true 로 View Transitions 이동도 집계. */}
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "24d231ca90664d5fac2bb7925dcb8249", "spa": true}'></script>
  </head>
  <body>
    <div class="page">
      <Header />
      <div class="layout">
        <div class="layout__body">
          <slot />
        </div>
        <Copyright />
      </div>
    </div>
  </body>
</html>

<style lang="scss">
  @import '../styles/variables';

  // 기존 Layout/style.scss 이식: 고정 헤더(45px)만큼 본문을 아래로 민다 + clearfix
  .page {
    margin-top: $header-height;
  }

  .layout__body::after {
    content: "";
    display: block;
    clear: both;
  }
</style>
