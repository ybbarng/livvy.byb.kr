---
// 가변 폰트(fontsource) — font-display:swap + unicode-range subset 내장.
// 브라우저가 글자에 맞는 언어 폰트만 자동으로 받는다.
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/noto-sans-kr';
import '@fontsource-variable/noto-sans-jp';
import '@fontsource-variable/noto-sans-sc';
import '@fontsource-variable/roboto';
// 전역 스타일 진입점(기존 Gatsby init.scss 그대로 이식)
import '../styles/init.scss';

import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Copyright from '../components/Copyright.astro';
import { site } from '../config/site';
import ogImage from '../assets/images/blog_logo_og.png';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  // 글별 OG 이미지 경로(예: /og/slug.png). 없으면 공통 로고 이미지를 쓴다.
  ogImage?: string;
}
const { title = site.title, description = site.subtitle, noindex = false, ogImage: ogImageProp } =
  Astro.props;
const fullTitle = title === site.title ? title : `${title} - ${site.title}`;
// 글별 OG는 1200×630 가로형(SNS 큰 카드), 공통 로고는 800×800 정사각형.
const ogImageUrl = ogImageProp
  ? new URL(ogImageProp, Astro.site).href
  : new URL(ogImage.src, Astro.site).href;
const ogImageWidth = ogImageProp ? 1200 : 800;
const ogImageHeight = ogImageProp ? 630 : 800;
const twitterCard = ogImageProp ? 'summary_large_image' : 'summary';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <script is:inline>
      // 다크모드: 렌더 전에 저장된/OS 선호 테마를 적용해 깜빡임을 막는다.
      // View Transitions로 페이지가 바뀔 때도 다시 적용해 테마가 유지되게 한다.
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem('theme');
            if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
            else document.documentElement.removeAttribute('data-theme');
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
    <ClientRouter />
    <script is:inline>
      // 옛 Gatsby(gatsby-plugin-offline) Service Worker 잔재 제거.
      // 남아 있으면 페이지 이동을 가로채 존재하지 않는 page-data.json 을 요청해 화면이 깨진다.
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then((rs) => rs.forEach((r) => r.unregister()));
        if (window.caches) caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
      }
    </script>
    {/* Cloudflare Web Analytics — 쿠키 없음·개인정보 미수집. spa:true 로 View Transitions 이동도 집계. */}
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "24d231ca90664d5fac2bb7925dcb8249", "spa": true}'></script>
  </head>
  <body>
    <div class="page">
      <Header />
      <div class="layout">
        <div class="layout__body">
          <slot />
        </div>
        <Copyright />
      </div>
    </div>
    <script>
      // 유튜브 facade 클릭 → 실제 재생 iframe(youtube-nocookie)으로 교체.
      // 이벤트 위임이라 View Transitions 로 페이지가 바뀌어도 한 번만 등록되면 된다.
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest('.yt-embed__btn');
        if (!btn) return;
        const wrap = btn.closest('.yt-embed');
        const id = wrap?.getAttribute('data-yt-id');
        if (!wrap || !id) return;
        const iframe = document.createElement('iframe');
        iframe.className = 'yt-embed__iframe';
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = '유튜브 영상';
        iframe.loading = 'lazy';
        iframe.allow =
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.allowFullscreen = true;
        wrap.replaceChildren(iframe);
      });

      // 트위터/X 위젯: 트윗이 있는 페이지에서만 스크립트를 불러오고,
      // 화면 전환(View Transitions) 때마다 새 트윗을 다시 렌더한다.
      function loadTweets() {
        if (!document.querySelector('.twitter-tweet')) return;
        // biome-ignore lint/suspicious/noExplicitAny: twttr 는 외부 스크립트가 주입하는 전역
        const w = window as any;
        if (w.twttr?.widgets) {
          w.twttr.widgets.load();
          return;
        }
        if (document.getElementById('twitter-wjs')) return;
        const s = document.createElement('script');
        s.id = 'twitter-wjs';
        s.src = 'https://platform.twitter.com/widgets.js';
        s.async = true;
        document.head.appendChild(s);
      }
      document.addEventListener('astro:page-load', loadTweets);

      // 정답 가리기(스포일러): 클릭 또는 Enter/Space 로 펼치기·접기.
      document.addEventListener('click', (e) => {
        const t = e.target;
        if (t instanceof Element) t.closest('.spoiler')?.classList.toggle('is-shown');
      });
      document.addEventListener('keydown', (e) => {
        const t = e.target;
        if ((e.key === 'Enter' || e.key === ' ') && t instanceof Element && t.classList.contains('spoiler')) {
          e.preventDefault();
          t.classList.toggle('is-shown');
        }
      });

      // 읽어주기(TTS): 글 본문에서 문장을 선택하면 뜨는 버튼으로 음성 재생.
      // 언어는 글자 종류로 자동 추정(일/한/중/프/영). 목소리는 사용자 기기에 설치된 것에 따름.
      if ('speechSynthesis' in window) {
        let btn: HTMLButtonElement | null = null;
        const detectLang = (t: string) => {
          if (/[぀-ヿ]/.test(t)) return 'ja-JP';
          if (/[가-힣]/.test(t)) return 'ko-KR';
          if (/[一-鿿]/.test(t)) return 'zh-CN';
          // 프랑스어: 발음기호가 있거나, 프랑스어 특유 단어가 보이면 fr (없으면 영어로 취급)
          if (/[àâçéèêëîïôûùüÿœæ]/i.test(t)) return 'fr-FR';
          if (
            /\b(bonjour|merci|salut|oui|c'est|est|être|vous|nous|je|tu|une|des|les|avec|pour|dans|mais|aussi|beaucoup)\b/i.test(
              t,
            )
          )
            return 'fr-FR';
          return 'en-US';
        };
        const hide = () => {
          if (btn) btn.style.display = 'none';
        };
        const ensureBtn = () => {
          if (btn && document.body.contains(btn)) return btn;
          btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'read-aloud';
          btn.textContent = '🔊 읽어주기';
          btn.style.display = 'none';
          btn.addEventListener('mousedown', (e) => e.preventDefault());
          btn.addEventListener('click', () => {
            const text = (window.getSelection()?.toString() || '').trim();
            if (!text) return;
            speechSynthesis.cancel();
            const u = new SpeechSynthesisUtterance(text);
            u.lang = detectLang(text);
            speechSynthesis.speak(u);
            hide();
          });
          document.body.appendChild(btn);
          return btn;
        };
        const onSelect = () => {
          const sel = window.getSelection();
          const text = (sel?.toString() || '').trim();
          if (!sel || !text || !sel.rangeCount) return hide();
          const node = sel.anchorNode;
          const el = node ? (node instanceof Element ? node : node.parentElement) : null;
          if (!el || !el.closest('.post-single__body')) return hide();
          const rect = sel.getRangeAt(0).getBoundingClientRect();
          const b = ensureBtn();
          b.style.display = 'block';
          b.style.top = `${window.scrollY + rect.top - 42}px`;
          b.style.left = `${window.scrollX + rect.left}px`;
        };
        document.addEventListener('mouseup', () => setTimeout(onSelect, 10));
        document.addEventListener('selectionchange', () => {
          if (!window.getSelection()?.toString().trim()) hide();
        });
      }
    </script>
  </body>
</html>

<style lang="scss">
  @import '../styles/variables';

  // 기존 Layout/style.scss 이식: 고정 헤더(45px)만큼 본문을 아래로 민다 + clearfix
  .page {
    margin-top: $header-height;
  }

  .layout__body::after {
    content: "";
    display: block;
    clear: both;
  }
</style>
