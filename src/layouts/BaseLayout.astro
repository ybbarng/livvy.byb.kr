---
// 가변 폰트(fontsource) — font-display:swap + unicode-range subset 내장.
// 브라우저가 글자에 맞는 언어 폰트만 자동으로 받는다.
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/noto-sans-kr';
import '@fontsource-variable/noto-sans-jp';
import '@fontsource-variable/noto-sans-sc';
import '@fontsource-variable/roboto';
// 전역 스타일 진입점(기존 Gatsby init.scss 그대로 이식)
import '../styles/init.scss';
// fontello 아이콘 폰트(소셜 링크용)
import '../assets/fonts/fontello-3d8dd48a/css/fontello.css';

import Header from '../components/Header.astro';
import Copyright from '../components/Copyright.astro';
import { site } from '../config/site';
import ogImage from '../assets/images/blog_logo_og.png';

interface Props {
  title?: string;
  description?: string;
}
const { title = site.title, description = site.subtitle } = Astro.props;
const fullTitle = title === site.title ? title : `${title} - ${site.title}`;
const ogImageUrl = new URL(ogImage.src, Astro.site).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // 다크모드: 렌더 전에 저장된/OS 선호 테마를 적용해 깜빡임을 막는다.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        } catch (e) {}
      })();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:locale" content="ko_KR" />
    <link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
    <script is:inline>
      // 옛 Gatsby(gatsby-plugin-offline) Service Worker 잔재 제거.
      // 남아 있으면 페이지 이동을 가로채 존재하지 않는 page-data.json 을 요청해 화면이 깨진다.
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then((rs) => rs.forEach((r) => r.unregister()));
        if (window.caches) caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
      }
    </script>
  </head>
  <body>
    <div class="page">
      <Header />
      <div class="layout">
        <div class="layout__body">
          <slot />
        </div>
        <Copyright />
      </div>
    </div>
  </body>
</html>

<style lang="scss">
  @import '../styles/variables';

  // 기존 Layout/style.scss 이식: 고정 헤더(45px)만큼 본문을 아래로 민다 + clearfix
  .page {
    margin-top: $header-height;
  }

  .layout__body::after {
    content: "";
    display: block;
    clear: both;
  }
</style>
