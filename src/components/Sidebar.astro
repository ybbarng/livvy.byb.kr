---
import { Image } from 'astro:assets';
import { site } from '../config/site';
import mainPhoto from '../assets/images/main_photo.jpg';

interface Props {
  isIndex?: boolean;
}
const { isIndex = false } = Astro.props;
---

<div class="sidebar">
  <div class="sidebar__inner">
    <div class="sidebar__group">
      <a href="/">
        <Image
          class="sidebar__group-photo"
          src={mainPhoto}
          width={145}
          height={257}
          alt={site.group.name}
          loading="eager"
          fetchpriority="high"
        />
      </a>
      {
        isIndex ? (
          <h1 class="sidebar__group-title">
            <a class="sidebar__group-title-link" href="/">{site.group.name}</a>
          </h1>
        ) : (
          <h2 class="sidebar__group-title">
            <a class="sidebar__group-title-link" href="/">{site.group.name}</a>
          </h2>
        )
      }
      <p class="sidebar__group-subtitle">{site.subtitle}</p>
    </div>
  </div>
</div>

<style lang="scss">
  @import '../styles/variables';
  @import '../styles/mixins';

  .sidebar {
    width: 100%;

    &__inner {
      position: relative;
      padding: 25px 20px 0;
    }

    &__group {
      &-photo {
        display: inline-block;
        width: 145px;
        height: 257px;
        margin-bottom: 0;
        background-clip: padding-box;
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
      }

      &-title {
        font-size: $typographic-base-font-size * 1.125;
        font-weight: 500;
        @include line-height(1.125);
        @include margin(.5, 0, .5, 0);

        &-link {
          color: $color-base;

          &:hover,
          &:focus {
            color: $color-base;
          }
        }
      }

      &-subtitle {
        color: $color-gray;
        @include line-height(1);
        @include margin-bottom(1);
      }
    }
  }

  @include breakpoint-sm {
    .sidebar {
      // lost-column: 5/12 대체 (content 7/12 와 나란히)
      float: left;
      width: calc(99.9% * 5 / 12 - (30px - 30px * 5 / 12));
      margin-right: 30px;

      &__inner {
        padding: 30px 20px 0;

        &:after {
          background: linear-gradient(to bottom, $color-gray-border 0%, $color-gray-border 48%, $color-white 100%);
          position: absolute;
          content: "";
          width: 1px;
          height: 400px;
          top: 30px;
          right: -10px;
          bottom: 0;
        }
      }
    }
  }

  @include breakpoint-md {
    .sidebar {
      // lost-column: 1/3 대체
      width: calc(99.9% * 1 / 3 - (30px - 30px * 1 / 3));

      &__inner {
        padding: 40px;
      }
    }
  }
</style>
