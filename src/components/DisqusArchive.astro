---
// 예전 Disqus 댓글을 빌드 시점에 정적으로 렌더하는 읽기 전용 아카이브.
// 데이터: src/data/disqus-comments.json (글 slug -> 댓글[] , 답글은 replies).
// 새 댓글은 아래 Giscus 가 담당하고, 이 블록은 옛 기록 보존용이다.
import archive from '../data/disqus-comments.json';
import { koreanDate } from '../lib/date';

interface Comment {
  author: string;
  authorId: string;
  date: string;
  body: string;
  replies?: Comment[];
}

const { slug } = Astro.props as { slug: string };
const comments: Comment[] = (archive as Record<string, Comment[]>)[slug] ?? [];
---

{
  comments.length > 0 && (
    <section class="archive">
      <div class="archive__head">
        <h2 class="archive__title">예전 댓글</h2>
        <span class="archive__badge">Disqus 보관</span>
      </div>
      <p class="archive__desc">예전에 Disqus에 남겼던 댓글이에요. 읽기 전용으로 보관합니다.</p>
      <ul class="archive__list">
        {comments.map((c) => (
          <li class={`archive__item is-${c.authorId}`}>
            <div class="archive__meta">
              <span class="archive__author">{c.author}</span>
              <time class="archive__date" datetime={c.date}>
                {koreanDate(c.date)}
              </time>
            </div>
            <p class="archive__body">{c.body}</p>
            {c.replies && c.replies.length > 0 && (
              <ul class="archive__replies">
                {c.replies.map((r) => (
                  <li class={`archive__item is-${r.authorId}`}>
                    <div class="archive__meta">
                      <span class="archive__author">{r.author}</span>
                      <time class="archive__date" datetime={r.date}>
                        {koreanDate(r.date)}
                      </time>
                    </div>
                    <p class="archive__body">{r.body}</p>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </section>
  )
}

<style lang="scss">
  @import '../styles/variables';
  @import '../styles/mixins';

  .archive {
    max-width: $layout-post-single-width;
    margin: 0 auto;
    @include margin-top(1);
  }

  .archive__head {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .archive__title {
    margin: 0;
    font-size: 1.15rem;
  }

  .archive__badge {
    font-size: 12px;
    color: $color-gray;
    border: 1px solid $color-gray-border;
    border-radius: 10px;
    padding: 1px 8px;
  }

  .archive__desc {
    margin: 4px 0 18px;
    color: $color-gray;
    font-size: $typographic-small-font-size;
  }

  .archive__list,
  .archive__replies {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .archive__item {
    border-left: 3px solid $color-gray-border;
    padding: 4px 0 4px 14px;
    margin-bottom: 14px;

    // 두 사람을 은은하게 구분
    &.is-ybbarng {
      border-left-color: $color-primary;
    }
    &.is-livvy {
      border-left-color: $color-secondary;
    }
  }

  .archive__replies {
    margin: 12px 0 0 22px;
  }

  .archive__meta {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 3px;
  }

  .archive__author {
    font-weight: 600;
  }

  .archive__date {
    color: $color-gray;
    font-size: 12px;
  }

  .archive__body {
    margin: 0;
    line-height: 1.6;
    word-break: break-word;
  }
</style>
