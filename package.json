{
  "name": "livvy.byb.kr",
  "version": "2.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "현지와 용배의 블로그 — Astro + 마크다운",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/normalize-cms-images.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "lefthook install"
  },
  "repository": "git+https://github.com/ybbarng/livvy.byb.kr.git",
  "author": "Bang Yongbae <ybbarng@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/noto-sans": "^5.3.0",
    "@fontsource-variable/noto-sans-jp": "^5.3.0",
    "@fontsource-variable/noto-sans-kr": "^5.3.0",
    "@fontsource-variable/noto-sans-sc": "^5.3.0",
    "@fontsource-variable/roboto": "^5.3.0",
    "astro": "^7.1.3",
    "astro-expressive-code": "^0.44.1",
    "lodash-es": "^4.18.1",
    "sass": "^1.101.6",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.5",
    "@fontsource/noto-sans-kr": "^5.3.0",
    "@types/lodash-es": "^4.17.12",
    "astro-og-canvas": "^0.13.0",
    "canvaskit-wasm": "0.41.1",
    "lefthook": "^2.1.10",
    "pagefind": "^1.5.2",
    "playwright": "^1.61.1",
    "postcss-pxtorem": "^6.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "sharp"
    ]
  }
}
